# --- Qdrant (источник чанков) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=
# Поле payload с текстом чанка (пусто = автоопределение)
# QDRANT_TEXT_FIELD=

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# --- LLM (OpenAI-совместимый endpoint) ---
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=
EMBEDDING_MODEL=

# --- Извлечение ---
EXTRACT_BATCH_SIZE=5
EXTRACT_CONCURRENCY=4
EXTRACT_MAX_CHARS=6000
LLM_NUM_PREDICT=4096

# --- Поиск ---
TOP_K_VECTOR=10
GRAPH_NEIGHBOR_DEPTH=2

# --- Сервис ---
API_PORT=8200
